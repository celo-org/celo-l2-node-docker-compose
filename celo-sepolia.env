###############################################################################
#                                ↓ REQUIRED ↓                                 #
###############################################################################

# Network to run the node on ("mainnet", "celo-sepolia")
NETWORK_NAME=celo-sepolia

# Type of node to run ("full" or "archive"), note that "archive" is 10x bigger
NODE_TYPE=full

###############################################################################
#                            ↓ REQUIRED (BEDROCK) ↓                           #
###############################################################################

# L1 node that the op-node (Bedrock) will get chain data from.
# To ensure reliability node operators may wish to change this to point at a service they trust.
OP_NODE__RPC_ENDPOINT=https://ethereum-sepolia-rpc.publicnode.com

# L1 beacon endpoint, you can setup your own or use Quicknode.
# To ensure reliability node operators may wish to change this to point at a service they trust.
OP_NODE__L1_BEACON=https://ethereum-sepolia-beacon-api.publicnode.com

# Type of RPC that op-node is connected to, see README
OP_NODE__RPC_TYPE=basic

# Reference L2 node to run healthcheck against
HEALTHCHECK__REFERENCE_RPC_PROVIDER=https://forno.celo-sepolia.celo-testnet.org

###############################################################################
#                            ↓ OPTIONAL (BEDROCK) ↓                           #
###############################################################################

# Path to the datadir, If the datadir is empty then a new datadir will be
# initialised at the given path. Datadirs written by op-geth cannot be reused;
# op-reth needs an empty directory and will sync from scratch.
#
# The path can be absolute, or relative to the docker-compose.yml file.
DATADIR_PATH=./envs/${NETWORK_NAME}/datadir

# When true, bootstrap an empty datadir from a published snapshot
# (snapshots.celo.org) instead of syncing from scratch, which is much faster.
# The snapshot matches NODE_TYPE (full or archive). Ignored once the datadir
# already holds data, so it is safe to leave enabled across restarts.
OP_RETH__SNAPSHOT=false

# Controls how op-reth determines its public IP that is shared via the
# discovery mechanism. The value should be one of
# (any|none|upnp|publicip|extip:<IP>|stun:<IP:PORT>) if any is selected
# op-reth will try to automatically determine its external IP. To explicitly
# set the IP that op-reth can be reached on use extip:<your-external-ip>.
# You can use the admin_nodeInfo RPC to query the value op-reth is using.
# If unset other nodes on the network will not be able to discover and
# connect to your node.
OP_RETH__NAT=any

# This controls the IP that op-node shares with the network so that other nodes may discover and connect to it.
# To check the value that op-node is currently using you can look in the logs for an entry such as:
# msg="started p2p host" addrs="[/ip4/127.0.0.1/tcp/9222 /ip4/192.168.97.9/tcp/9222]" peerID=16Uiu2HAkv7PQ5hpa2HeWgjYQ7SChvipCWm3L95hUKejSKMM4rVPe
# alternatively you can use the op-node opp2p_self RPC to query this
# information. If unset other nodes will not be then other nodes on the network
# will not be able to discover and connect to your node.
OP_NODE__P2P_ADVERTISE_IP=

###############################################################################
#                            ↓ REQUIRED (EIGENDA) ↓                           #
###############################################################################

# Specifies the endpoint of the eigenda proxy to use. If this is unset then a local eigenda proxy will be used.
EIGENDA_PROXY_ENDPOINT=

EIGENDA_LOCAL_SVC_MANAGER_ADDR=0x3a5acf46ba6890B8536420F4900AC9BC45Df4764
EIGENDA_LOCAL_DISPERSER_RPC=disperser-testnet-sepolia.eigenda.xyz:443
EIGENDA_V2_LOCAL_CERT_VERIFIER_ROUTER_ADDR=0xf4f934A0b5c09d302d9C6f60040754fEebdd6073
EIGENDA_V2_LOCAL_NETWORK=sepolia_testnet

###############################################################################
#                            ↓ OPTIONAL (EIGENDA) ↓                           #
###############################################################################

EIGENDA_LOCAL_S3_CREDENTIAL_TYPE="public"
EIGENDA_LOCAL_S3_ACCESS_KEY_ID=""
EIGENDA_LOCAL_S3_ACCESS_KEY_SECRET=""
EIGENDA_LOCAL_S3_BUCKET="eigenda-proxy-cache-celo-sepolia"
EIGENDA_LOCAL_S3_PATH="blobs/"
EIGENDA_LOCAL_S3_ENDPOINT="storage.googleapis.com"
EIGENDA_LOCAL_ARCHIVE_BLOBS=${EIGENDA_LOCAL_S3_BUCKET:+0}

###############################################################################
#                            ↓ REQUIRED (CHALLENGER) ↓                           #
###############################################################################

CHALLENGER__ENABLED=false
CHALLENGER__PRIVATE_KEY="0x0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

###############################################################################
#                            ↓ OPTIONAL (CHALLENGER) ↓                           #
###############################################################################

CHALLENGER__FETCH_INTERVAL_SECONDS=
CHALLENGER__DISABLE_MONITOR_ONLY_MODE=false
CHALLENGER__TX_CONFIRMATION_TIMEOUT_SECONDS=

###############################################################################
#                                ↓ OPTIONAL ↓                                 #
###############################################################################

# MONITORING_ENABLED controls whether Grafana, Prometheus, Influxdb, and Healthcheck are started
# Set to "true" if you want to launch them, otherwise keep "false"
MONITORING_ENABLED=false

IMAGE_TAG__HEALTHCHECK=
IMAGE_TAG__PROMETHEUS=
IMAGE_TAG__GRAFANA=
IMAGE_TAG__INFLUXDB=
IMAGE_TAG__OP_RETH=
IMAGE_REPO__OP_RETH=
IMAGE_TAG__OP_NODE=
IMAGE_TAG__CHALLENGER=

# Exposed server ports (must be unique)
# See docker-compose.yml for default values
PORT__HISTORICAL_RPC_NODE_HTTP=
PORT__HISTORICAL_RPC_NODE_WS=
PORT__HEALTHCHECK_METRICS=
PORT__PROMETHEUS=
PORT__GRAFANA=
PORT__INFLUXDB=
PORT__OP_RETH_HTTP=
PORT__OP_RETH_WS=
PORT__OP_RETH_P2P=30303
PORT__OP_NODE_P2P=
PORT__OP_NODE_HTTP=
PORT_EIGENDA_PROXY=
